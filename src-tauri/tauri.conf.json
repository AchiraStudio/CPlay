{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VAULT",
  "version": "0.1.0",
  "identifier": "com.vault.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "A Vault",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "visible": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "A Vault Overlay",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "url": "overlay.html",
        "x": 0,
        "y": 0,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}